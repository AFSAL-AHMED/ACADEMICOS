# ScholarAI Environment Variables
# Copy this file to .env and fill in your values.

# 1. Your Notion Internal Integration Secret (starts with ntn_)
NOTION_API_KEY="your_notion_api_key_here"

# 2. The 32-character ID of the Notion Page where ScholarAI will build the workspace
# (You get this from the end of the Notion page URL)
NOTION_PAGE_ID="your_notion_page_id_here"
